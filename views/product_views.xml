<odoo>
    <record id="view_product_template_form_inherit_mrp_dashboard" model="ir.ui.view">
        <field name="name">product.template.form.inherit.mrp.dashboard</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-block">
                    <field name="show_on_mrp_dashboard"/>
                    <label for="show_on_mrp_dashboard"/>
                </span>
            </xpath>
        </field>
    </record>
</odoo>