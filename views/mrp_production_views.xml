<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mrp_workorder_timeline" model="ir.ui.view">
        <field name="name">mrp.workorder.timeline</field>
        <field name="model">mrp.workorder</field>
        <field name="arch" type="xml">
            <timeline date_start="date_start"
                      date_stop="date_finished"
                      default_group_by="workcenter_id"
                      event_open_popup="true"
                      colors="#ec7063:state=='cancel';#2ecc71:state=='done';#f1c40f:state=='ready';#3498db:state=='progress';#bdc3c7:state=='pending'">
                <field name="name"/>
                <field name="production_id"/>
                <field name="workcenter_id"/>
                <field name="product_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="timeline-item">
                        <div class="o_timeline_item_content">
                            <t t-esc="record.production_id[1]"/> | <t t-esc="record.product_id[1]"/>
                        </div>
                    </t>
                </templates>
            </timeline>
        </field>
    </record>

    <record id="mrp.mrp_workorder_todo" model="ir.actions.act_window">
        <field name="view_mode">list,kanban,form,calendar,pivot,graph,timeline</field>
        <field name="domain">[('state', 'not in', ('done', 'cancel')), ('date_start', '!=', False)]</field>
    </record>

    <record id="mrp_workorder_view_form_inherit_timeline" model="ir.ui.view">
        <field name="name">mrp.workorder.form.inherit.timeline</field>
        <field name="model">mrp.workorder</field>
        <field name="inherit_id" ref="mrp.mrp_production_workorder_form_view_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_mo" type="object" class="oe_stat_button" icon="fa-cogs">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Üretim Emrine Git</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>