<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_management_dashboard_projects" model="ir.actions.act_window">
        <field name="name">Proje Özeti</field>
        <field name="res_model">project.project</field>
        <field name="view_mode">kanban,list,form</field>

        <field name="domain">[('last_update_status', '=', 'on_track')]</field>

        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Sistemde durumu "İzleme Açık" (Yeşil) olan hiçbir proje bulunamadı!
            </p>
        </field>
    </record>


    <menuitem id="menu_management_root"
              name="Yönetim"
              sequence="0"
              web_icon="project,static/description/icon.png"/>

    <menuitem id="menu_management_projects"
              name="Projeler"
              parent="menu_management_root"
              action="action_management_dashboard_projects"
              sequence="10"/>

    <!-- Eski menü kaydını temizle (orphan action referansı) -->
    <delete id="menu_management_operations" model="ir.ui.menu"/>

    <!-- Operasyonlar: Alt menüleri olan parent menü -->
    <menuitem id="parent_menu_operations"
              name="Operasyonlar"
              parent="menu_management_root"
              sequence="20"/>

    <!-- ============================================ -->
    <!--       Üretim Emirleri - Search View          -->
    <!-- ============================================ -->
    <record id="search_mrp_production_management" model="ir.ui.view">
        <field name="name">mrp.production.search.management</field>
        <field name="model">mrp.production</field>
        <field name="arch" type="xml">
            <search string="Üretim Emirleri Ara">
                <!-- Arama Alanları -->
                <field name="name" string="Üretim Emri"/>
                <field name="product_id" string="Ürün"/>
                <field name="kalip_id" string="Kalıp"/>
                <field name="project_id" string="Proje"/>

                <!-- Tarih Filtreleri -->
                <separator/>
                <filter string="Bugün" name="filter_today"
                        domain="[('date_start', '&gt;=', (context_today()).strftime('%Y-%m-%d 00:00:00')),
                                 ('date_start', '&lt;', (context_today() + datetime.timedelta(days=1)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="Yarın" name="filter_tomorrow"
                        domain="[('date_start', '&gt;=', (context_today() + datetime.timedelta(days=1)).strftime('%Y-%m-%d 00:00:00')),
                                 ('date_start', '&lt;', (context_today() + datetime.timedelta(days=2)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="Dün" name="filter_yesterday"
                        domain="[('date_start', '&gt;=', (context_today() - datetime.timedelta(days=1)).strftime('%Y-%m-%d 00:00:00')),
                                 ('date_start', '&lt;', (context_today()).strftime('%Y-%m-%d 00:00:00'))]"/>


                <filter string="Geçmiş Üretimler" name="filter_past"
                        domain="[('date_start', '&lt;', (context_today()).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="Gelecek Üretimler" name="filter_future"
                        domain="[('date_start', '&gt;=', (context_today() + datetime.timedelta(days=1)).strftime('%Y-%m-%d 00:00:00'))]"/>

                <!-- Durum Filtreleri -->
                <separator/>
                <filter string="Planlanmış" name="filter_planned"
                        domain="[('is_planned', '=', True)]"/>
                <filter string="Devam Eden" name="filter_in_progress"
                        domain="[('state', '=', 'progress')]"/>
                <filter string="Tamamlanan" name="filter_done"
                        domain="[('state', '=', 'done')]"/>

                <!-- Gruplama -->
                <group expand="0" string="Grupla">
                    <filter string="Kalıp" name="group_kalip" context="{'group_by': 'kalip_id'}"/>
                    <filter string="Ürün" name="group_product" context="{'group_by': 'product_id'}"/>
                    <filter string="Proje" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Durum" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Başlangıç Tarihi" name="group_date_start" context="{'group_by': 'date_start:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================ -->
    <!--       Üretim Emirleri - Action               -->
    <!-- ============================================ -->
    <record id="action_management_production_orders" model="ir.actions.act_window">
        <field name="name">Üretim Emirleri</field>
        <field name="res_model">mrp.production</field>
        <field name="view_mode">kanban,list,form,calendar</field>
        <field name="search_view_id" ref="search_mrp_production_management"/>
        <field name="domain">[('is_planned', '=', True)]</field>
        <field name="context">{
            'search_default_filter_today': 1,
            'search_default_group_kalip': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Bugün için planlanmış üretim emri bulunamadı.
            </p>
        </field>
    </record>

    <menuitem id="menu_management_production_orders"
              name="Üretim Emirleri"
              parent="parent_menu_operations"
              action="action_management_production_orders"
              sequence="10"/>

    <!-- ============================================ -->
    <!--       İş Emirleri - Action                   -->
    <!-- ============================================ -->
    <record id="action_management_work_orders" model="ir.actions.act_window">
        <field name="name">İş Emirleri</field>
        <field name="res_model">mrp.workorder</field>
        <field name="view_mode">list,form,kanban,calendar,timeline</field>
        <!-- Standart mpr.workorder search view'ını kullanabiliriz, özel gerekirse ekleriz -->
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Henüz iş emri bulunamadı.
            </p>
        </field>
    </record>

    <menuitem id="menu_management_work_orders"
              name="İş Emirleri"
              parent="parent_menu_operations"
              action="action_management_work_orders"
              sequence="20"/>

    <record id="view_project_kanban_inherit_management" model="ir.ui.view">
        <field name="name">project.project.kanban.inherit.management</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//footer" position="before">
                <field name="production_summary_html" invisible="1"/>
                <field name="production_percent" invisible="1"/>

                <div class="w-100 px-2 pb-2" onclick="event.stopPropagation();">

                    <details style="margin-bottom: 5px; border: 1px solid #dee2e6; border-radius: 4px; overflow: hidden; background-color: #fff;">
                        <summary style="cursor: pointer; padding: 5px 8px; background-color: #f8f9fa; font-size: 11px; font-weight: bold; list-style: none; display: flex; justify-content: space-between; align-items: center; margin: 0;">
                            <span style="color: #2c3e50;"><i class="fa fa-cogs me-1"></i> Üretim</span>
                            <span t-attf-class="badge rounded-pill text-bg-#{record.production_percent.raw_value == 100 ? 'success' : 'primary'}">
                                % <t t-esc="record.production_percent.raw_value"/>
                            </span>
                        </summary>
                        <div style="padding: 5px; border-top: 1px solid #dee2e6;">
                            <a type="object" name="action_open_project_mos" style="text-decoration: none; color: inherit; display: block; cursor: pointer;" title="Üretim Emirlerini Aç">
                                <t t-out="record.production_summary_html.raw_value"/>
                            </a>
                        </div>
                    </details>

                    <details style="margin-bottom: 5px; border: 1px solid #dee2e6; border-radius: 4px; overflow: hidden; background-color: #fff;">
                        <summary style="cursor: pointer; padding: 5px 8px; background-color: #f8f9fa; font-size: 11px; font-weight: bold; list-style: none; display: flex; justify-content: space-between; align-items: center; margin: 0;">
                            <span style="color: #d35400;"><i class="fa fa-truck me-1"></i> Sevkiyat</span>
                            <span class="badge rounded-pill text-bg-secondary">% 0</span>
                        </summary>
                        <div style="padding: 8px; border-top: 1px solid #dee2e6; font-size: 10px; color: #6c757d; text-align: center;">
                            Sevkiyat hesaplamaları yakında eklenecek...
                        </div>
                    </details>

                    <details style="border: 1px solid #dee2e6; border-radius: 4px; overflow: hidden; background-color: #fff;">
                        <summary style="cursor: pointer; padding: 5px 8px; background-color: #f8f9fa; font-size: 11px; font-weight: bold; list-style: none; display: flex; justify-content: space-between; align-items: center; margin: 0;">
                            <span style="color: #16a085;"><i class="fa fa-wrench me-1"></i> Montaj</span>
                            <span class="badge rounded-pill text-bg-secondary">% 0</span>
                        </summary>
                        <div style="padding: 8px; border-top: 1px solid #dee2e6; font-size: 10px; color: #6c757d; text-align: center;">
                            Montaj hesaplamaları yakında eklenecek...
                        </div>
                    </details>

                </div>
            </xpath>
        </field>
    </record>

</odoo>